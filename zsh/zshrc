function esmb {
  BRANCH=`git rev-parse --abbrev-ref HEAD`
  if [[ "$BRANCH" == "dev" ]]; then echo "Cannot do this operation on dev."; return; fi
  echo "Merging $BRANCH into dev...";
  git rebase dev && git checkout dev && git rebase $BRANCH && git branch -D $BRANCH
}

function esmybr {
git for-each-ref \
  --sort=-committerdate \
  --format='%(refname:short) | %(committerdate:relative) | %(subject)' \
  "refs/heads/kc" \
| while IFS='|' read -r branch date subject; do
    printf "%s | %s | %.40s\n" "$branch" "$date" "$subject"
  done \
| column -t -s '|'
}

