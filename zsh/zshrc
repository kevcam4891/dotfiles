function gmb {
  BRANCH=`git rev-parse --abbrev-ref HEAD`
  if [[ "$BRANCH" == "main" ]]; then echo "Cannot do this operation on main."; return; fi
  echo "Merging $BRANCH into main...";
  git rebase main && git checkout main && git rebase $BRANCH && git branch -D $BRANCH
}

# Delete local and upstream branch in ExamSpark repo
function esdelbr {
  BRANCH=`git rev-parse --abbrev-ref HEAD`
  if [[ "$BRANCH" == "$1" ]]; then
    echo "Cannot delete the current branch ($1). Please switch to another branch first."
    return 1
  fi
  git push -d upstream $1 --force --no-verify 2>/dev/null; git branch -D $1 2>/dev/null
}

